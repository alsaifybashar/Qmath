# Generate independently for every environment: openssl rand -base64 48
AUTH_SECRET=
AUDIT_HMAC_KEY=

# Turso/libSQL (use a separate database for Preview and Production)
TURSO_DATABASE_URL=libsql://database-name-organization.turso.io
TURSO_AUTH_TOKEN=

# Private Vercel Blob store
BLOB_READ_WRITE_TOKEN=

# Distributed, fail-closed abuse controls
# Direct Upstash credentials use these names. Vercel's Marketplace integration
# may instead inject KV_REST_API_URL and KV_REST_API_TOKEN; both are supported.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Configure a direct provider key when not using Vercel AI Gateway. On Vercel,
# VERCEL_OIDC_TOKEN is injected automatically and no static AI key is required.
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
AI_GATEWAY_API_KEY=
AI_PROVIDER=anthropic

# Only enable when Vercel is behind another trusted proxy that overwrites this header.
TRUST_PROXY_IP_HEADER=false
